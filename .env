COMPOSE_PROJECT_NAME=cityxai
MUNICIPALITY_NAME=Stadt Paderborn
MUNICIPALITY_NAMESPACE=paderborn
ADMIN_EMAIL=admin@demo.de
ADMIN_PASSWORD=Demo1234!
JWT_SECRET=change-me
DB_ENCRYPT_KEY=change-me-too
# Keycloak issuer URL — must match the `iss` claim in tokens (external URL via nginx proxy)
KEYCLOAK_ISSUER=https://localhost/realms/cityxai
# Allowed CORS origin for admin portal and APIs
FRONTEND_ORIGIN=https://localhost
# Maximum file upload size in MB
MAX_UPLOAD_MB=100
OLLAMA_PRIMARY_MODEL=qwen3:8b-q4_K_M
OLLAMA_FALLBACK_MODEL=mistral:7b-q4_K_M
EMBED_MODEL=nomic-embed-text:v1.5
CHUNK_SIZE=512
CHUNK_OVERLAP=50
RETRIEVAL_K=10
RERANK_TOP_N=5
# Number of top reranked chunks passed to the LLM as answer context
ANSWER_CONTEXT_TOP_N=3
CONFIDENCE_THRESHOLD=0.5
# Set to "true" to enable the demo/dev login bypass. Must be "false" in production.
DEMO_LOGIN_ENABLED=true
