{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "Query volume (queries/hour)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "sum(increase(paderobot_queries_total[1h]))", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "P50/P95/P99 response latency",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(chat_api_request_latency_seconds_bucket[5m])) by (le))", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(chat_api_request_latency_seconds_bucket[5m])) by (le))", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum(rate(chat_api_request_latency_seconds_bucket[5m])) by (le))", "refId": "C"}
      ]
    },
    {
      "type": "gauge",
      "title": "Ollama tokens/sec",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 8},
      "targets": [{"expr": "paderobot_ollama_tokens_per_sec", "refId": "A"}]
    },
    {
      "type": "gauge",
      "title": "Average retrieval score",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 8},
      "targets": [{"expr": "paderobot_avg_retrieval_score", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": 0},
              {"color": "orange", "value": 0.5},
              {"color": "green", "value": 0.7}
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Failed ingest rate",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
      "targets": [{"expr": "increase(ingest_api_failed_total[1h])", "refId": "A"}]
    },
    {
      "type": "barchart",
      "title": "Document count per namespace",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "targets": [{"expr": "sum by (classification) (ingest_api_documents_total)", "refId": "A"}]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "style": "dark",
  "templating": {"list": []},
  "time": {"from": "now-48h", "to": "now"},
  "title": "PadeRoBot+ Municipal AI",
  "version": 1
}
