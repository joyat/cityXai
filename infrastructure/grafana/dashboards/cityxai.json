{
  "__inputs": [{ "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Anfragen gesamt (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#00d4ff" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#00d4ff", "value": 0 }] }
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "increase(cityxai_queries_total[24h])", "refId": "A", "legendFormat": "Anfragen" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Ø Antwortzeit (ms)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "orange", "value": 2000 },
            { "color": "red", "value": 5000 }
          ]}
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "rate(chat_api_request_latency_seconds_sum[5m]) / rate(chat_api_request_latency_seconds_count[5m]) * 1000", "refId": "A", "legendFormat": "Ø Latenz" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Markierte Antworten (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "orange", "value": 5 },
            { "color": "red", "value": 20 }
          ]}
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "increase(cityxai_flagged_responses_total[24h])", "refId": "A", "legendFormat": "Markiert" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Ø Konfidenz-Score",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "orange", "value": 0.5 },
            { "color": "green", "value": 0.7 }
          ]}
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "cityxai_avg_retrieval_score", "refId": "A", "legendFormat": "Konfidenz" }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Anfragevolumen (Anfragen / Stunde)",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#00d4ff" },
          "custom": { "fillOpacity": 15, "lineWidth": 2, "gradientMode": "opacity" },
          "unit": "short"
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "sum(increase(cityxai_queries_total[1h]))", "refId": "A", "legendFormat": "Anfragen/h" }]
    },
    {
      "id": 6,
      "type": "gauge",
      "title": "Ollama Tokens/s",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "orange", "value": 5 },
            { "color": "green", "value": 15 }
          ]}
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "cityxai_ollama_tokens_per_sec", "refId": "A", "legendFormat": "Tokens/s" }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Antwortlatenz P50 / P95 / P99",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "P99" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ef4444" } }] },
          { "matcher": { "id": "byName", "options": "P95" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#f59e0b" } }] },
          { "matcher": { "id": "byName", "options": "P50" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#10b981" } }] }
        ]
      },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "histogram_quantile(0.50, sum(rate(chat_api_request_latency_seconds_bucket[5m])) by (le)) * 1000", "refId": "A", "legendFormat": "P50" },
        { "datasource": { "type": "prometheus" }, "expr": "histogram_quantile(0.95, sum(rate(chat_api_request_latency_seconds_bucket[5m])) by (le)) * 1000", "refId": "B", "legendFormat": "P95" },
        { "datasource": { "type": "prometheus" }, "expr": "histogram_quantile(0.99, sum(rate(chat_api_request_latency_seconds_bucket[5m])) by (le)) * 1000", "refId": "C", "legendFormat": "P99" }
      ]
    },
    {
      "id": 8,
      "type": "barchart",
      "title": "Dokumente nach Klassifizierung",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "sum by (classification) (ingest_api_documents_total)", "refId": "A", "legendFormat": "{{classification}}" }]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Fehlgeschlagene Ingests (1h)",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "red", "value": 1 }
          ]}
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "increase(ingest_api_failed_total[1h])", "refId": "A", "legendFormat": "Fehler" }]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["cityxai", "municipal", "ai"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "Europe/Berlin",
  "title": "cityXai — Kommunale KI-Plattform",
  "uid": "cityxai-main",
  "version": 2
}
