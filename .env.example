COMPOSE_PROJECT_NAME=cityxai
MUNICIPALITY_NAME=Stadt Paderborn
MUNICIPALITY_NAMESPACE=paderborn
ADMIN_EMAIL=admin@demo.de
ADMIN_PASSWORD=Demo1234!
JWT_SECRET=change-me
DB_ENCRYPT_KEY=change-me-too
# Keycloak issuer URL — used for RS256 token verification (leave default for local docker setup)
KEYCLOAK_ISSUER=https://localhost/realms/cityxai
# Allowed CORS origin for admin portal and APIs
FRONTEND_ORIGIN=https://localhost
# Maximum file upload size in MB (default 100)
MAX_UPLOAD_MB=100
USE_LM_STUDIO=true
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_TIMEOUT_SECONDS=180
OLLAMA_PRIMARY_MODEL=gemma-4-e4b-it
OLLAMA_FALLBACK_MODEL=gemma-4-e4b-it
EMBED_MODEL=text-embedding-nomic-embed-text-v1.5
CHUNK_SIZE=512
CHUNK_OVERLAP=50
RETRIEVAL_K=10
RERANK_TOP_N=5
# Number of top reranked chunks passed to the LLM as answer context (higher = more sources, slower)
ANSWER_CONTEXT_TOP_N=3
CONFIDENCE_THRESHOLD=0.5
# Set to "true" to enable the demo/dev login bypass (bypasses Keycloak). Must be "false" in production.
DEMO_LOGIN_ENABLED=true
