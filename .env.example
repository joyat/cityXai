COMPOSE_PROJECT_NAME=cityxai
MUNICIPALITY_NAME=Stadt Paderborn
MUNICIPALITY_NAMESPACE=paderborn
ADMIN_EMAIL=admin@demo.de
ADMIN_PASSWORD=Demo1234!
JWT_SECRET=change-me
DB_ENCRYPT_KEY=change-me-too
# Keycloak issuer URL — used for RS256 token verification (leave default for local docker setup)
KEYCLOAK_ISSUER=http://keycloak:8080/realms/cityxai
# Allowed CORS origin for admin portal and APIs
FRONTEND_ORIGIN=https://localhost
# Maximum file upload size in MB (default 100)
MAX_UPLOAD_MB=100
OLLAMA_PRIMARY_MODEL=qwen3:8b-q4_K_M
OLLAMA_FALLBACK_MODEL=mistral:7b-q4_K_M
EMBED_MODEL=nomic-embed-text:v1.5
CHUNK_SIZE=512
CHUNK_OVERLAP=50
RETRIEVAL_K=10
RERANK_TOP_N=5
CONFIDENCE_THRESHOLD=0.5
